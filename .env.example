# Site Configuration
# Required on Vercel. Use your canonical production URL.
NEXT_PUBLIC_SITE_URL=https://w4w.dev

# Admin Dashboard
# Required if /admin is enabled.
# ADMIN_PASSWORD=replace-this-with-a-long-random-password

# HMAC key for signing admin session tokens.
# Use a high-entropy random string (>= 32 bytes).
# Generate with: openssl rand -base64 32
# SESSION_SIGNING_KEY=replace-this-with-openssl-rand-base64-32

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry Error Tracking (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Debug / Build (optional)
# DEBUG=true
# LOG_LEVEL=debug
# ANALYZE=false
