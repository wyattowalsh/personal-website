# Site Configuration
NEXT_PUBLIC_SITE_URL=https://w4w.dev
# LINK_REWRITE_TARGET=https://your-shortener.example.com

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager (optional)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry Error Tracking (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=

# Debug mode (optional, dev only)
# DEBUG=true

# Log level (optional)
# LOG_LEVEL=debug

# Bundle Analyzer (optional, dev only)
# ANALYZE=true

# Studio — Database (required for /studio)
# POSTGRES_URL=postgres://user:pass@host/dbname?sslmode=require
# STUDIO_DB_QUERY_TIMEOUT_MS=5000
# STUDIO_DB_CIRCUIT_FAILURE_THRESHOLD=3
# STUDIO_DB_CIRCUIT_COOLDOWN_MS=30000

# Studio — Auth (required for /studio sign-in)
# AUTH_SECRET=openssl-rand-base64-32
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
